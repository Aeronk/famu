# ============================================================================
# Famu / Murimi OS — environment configuration
# Copy to `.env`. Every external integration is OPTIONAL: leave a key blank and
# that service runs in deterministic MOCK mode so the app boots with zero secrets.
# ============================================================================

# ---- App ----
APP_NAME="Murimi OS"
ENV=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
DEFAULT_LANGUAGE=en        # en | sn (Shona) | nd (Ndebele)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Security / JWT ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_ALGORITHM=HS256
# Optional Fernet key for field encryption. If blank, derived from SECRET_KEY.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ---- Database (async URL for the app) ----
# SQLite (default) needs no services — great for local dev. RAG vector search
# falls back to in-Python cosine similarity on SQLite.
DATABASE_URL=sqlite+aiosqlite:///./murimi.db
# For production / native pgvector RAG, use Postgres instead:
# DATABASE_URL=postgresql+asyncpg://murimi:murimi@localhost:5432/murimi
# Used by the test-suite; falls back to DATABASE_URL with a _test suffix.
TEST_DATABASE_URL=
# Defense-in-depth Postgres Row-Level Security (Postgres only; app-level filtering is always on).
ENABLE_RLS=false

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Rate limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# ---- OpenAI (blank => mock LLM, embeddings & vision) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# ---- Meta WhatsApp Cloud API (blank => messages are logged, not sent) ----
WHATSAPP_VERIFY_TOKEN=murimi-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0

# ---- Weather provider (blank => synthetic weather) ----
WEATHER_PROVIDER=openweather
WEATHER_API_KEY=

# ---- Notifications (blank => logged, not sent) ----
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=Murimi
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=no-reply@murimi.os
